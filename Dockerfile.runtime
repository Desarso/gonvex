FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/gonvex-runtime ./server/cmd/gonvex-runtime

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=build /out/gonvex-runtime /usr/local/bin/gonvex-runtime
ENV GONVEX_ADDR=0.0.0.0:8080
EXPOSE 8080
CMD ["gonvex-runtime"]

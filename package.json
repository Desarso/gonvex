{
  "name": "gonvex-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r build",
    "build:packages": "pnpm --filter @gonvex/protocol build && pnpm --filter @gonvex/client build && pnpm --filter @gonvex/react build && pnpm --filter gonvex build && pnpm --filter create-gonvex build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:go": "go test ./...",
    "dev:docs": "pnpm --filter @gonvex/docs dev",
    "dev:packages": "pnpm --parallel --filter @gonvex/protocol --filter @gonvex/client --filter @gonvex/react --filter gonvex --filter create-gonvex dev",
    "dev:dashboard": "pnpm --filter @gonvex/dashboard dev",
    "dev:cli": "go run ./cmd/gonvex dev --project apps/dashboard",
    "dev:runtime": "air -c .air.toml",
    "dev:runtime:air": "air -c .air.toml"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}

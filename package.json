{
  "name": "gonvex-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r build",
    "build:packages": "pnpm --filter @gonvex/protocol build && pnpm --filter @gonvex/client build && pnpm --filter @gonvex/react build && pnpm --filter @gonvex/cli build && pnpm --filter create-gonvex build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:go": "go test ./...",
    "test:release": "node --test scripts/release-cli.test.mjs",
    "release:cli": "node scripts/release-cli.mjs",
    "release:cli:dry-run": "node scripts/release-cli.mjs --dry-run",
    "release:notes": "node scripts/release-cli.mjs --notes-preview",
    "dev:docs": "pnpm --filter @gonvex/docs dev",
    "dev:packages": "pnpm --parallel --filter @gonvex/protocol --filter @gonvex/client --filter @gonvex/react --filter @gonvex/cli --filter create-gonvex dev",
    "dev:dashboard": "pnpm --filter @gonvex/dashboard dev",
    "dev:cli": "go run ./cmd/gonvex dev --project apps/dashboard",
    "dev:runtime": "air -c .air.toml",
    "dev:runtime:air": "air -c .air.toml",
    "seed:tasks": "go run ./cmd/seed-tasks",
    "seed:tasks:10m": "go run ./cmd/seed-tasks --count 10000000 --batch 50000 --seed 42 --clear --fast --no-trgm --analyze"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@firebase/util",
      "protobufjs"
    ],
    "onlyBuiltDependencies": [
      "@firebase/util",
      "esbuild",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "ws": "^8.21.0"
  }
}

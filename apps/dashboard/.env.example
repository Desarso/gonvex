VITE_GONVEX_URL=http://localhost:8080
VITE_GONVEX_PROJECT_ID=app
# Omit or set false to skip login in local development.
VITE_GONVEX_AUTH_ENABLED=false
VITE_GONVEX_DATABASE=gonvex_dev
VITE_GONVEX_STORAGE_BUCKET=gonvex-dev

VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-firebase-web-app-id
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Optional multi-project shape. Same runtime/Postgres server can route each
# project id to a different project database on the backend.
# VITE_GONVEX_PROJECTS=[{"id":"app","name":"Dashboard Lab","environment":"local dev","runtimeUrl":"http://localhost:8080","database":"gonvex_dev","storageBucket":"gonvex-dev","status":"local","description":"Dashboard project"}]

{
  "name": "gonvex",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "gonvex": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./src/react.ts",
      "default": "./dist/react.js"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "default": "./dist/browser.js"
    }
  },
  "types": "./src/index.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "prepack": "node scripts/copy-templates.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gonvex/client": "workspace:*",
    "@gonvex/react": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3"
  }
}

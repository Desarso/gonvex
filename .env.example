POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gonvex_dev
POSTGRES_SSLMODE=disable
POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/gonvex_dev?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/gonvex_dev?sslmode=disable
# Optional runtime-side project database routing. Each project can use the same
# Postgres server with a different database name.
# GONVEX_PROJECT_DATABASE_URLS={"app":"postgres://postgres:postgres@127.0.0.1:5432/gonvex_dev?sslmode=disable","runtime":"postgres://postgres:postgres@127.0.0.1:5432/gonvex_runtime_dev?sslmode=disable"}

VALKEY_URL=redis://127.0.0.1:6380/0
GONVEX_ROWS_CACHE_TTL=10m
GONVEX_TENANT_LISTENER_LIMIT=64
GONVEX_TENANT_LISTENER_IDLE_TIMEOUT=1m
GONVEX_SHARED_RESULT_MAX_BYTES=8388608
GONVEX_SHARED_SUBSCRIPTION_GRACE=15s
GONVEX_SHARED_SUBSCRIPTION_MAX_FANOUT=10000

# PostgreSQL connection pooling. These limits apply to each active tenant pool.
# The total budget defaults to 20 and can be raised to at most 64 connections
# per runtime process. Divide the PostgreSQL allocation across runtime replicas;
# the per-process ceiling cannot coordinate capacity between separate containers.
# Budgeted pools retain at most one warm connection per database and expire it
# after one second, allowing dormant tenants to release their global budget slot.
GONVEX_DB_MAX_OPEN_CONNS=16
GONVEX_DB_MAX_IDLE_CONNS=1
GONVEX_DB_MAX_TOTAL_CONNS=20

# Optional: only required when using file APIs. These values match the
# example MinIO service started by `make storage`. Any S3-compatible
# storage provider can be used instead.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=gonvex-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Browser-facing runtime origin. Required for Convex-compatible POST uploads:
# the runtime proxies storage traffic here instead of exposing MinIO/S3 URLs.
GONVEX_PUBLIC_URL=http://localhost:8080

# Optional native Google login. Configure one web OAuth client for the Gonvex
# runtime, with this authorized redirect URI:
#   http://localhost:8080/auth/google/callback
# Hosted runtimes must use their externally reachable HTTPS origin instead.
GONVEX_AUTH_URL=http://localhost:8080
# GONVEX_GOOGLE_CLIENT_ID=1234567890-example.apps.googleusercontent.com
# GONVEX_GOOGLE_CLIENT_SECRET=replace-me

# Optional: let the Gonvex dashboard use native Google login too. Set this to
# one dedicated Gonvex project configured with the dashboard origin's /login
# callback, and use the same value as VITE_GONVEX_DASHBOARD_AUTH_PROJECT_ID
# when building apps/dashboard. Only this project's sessions are trusted by
# control-plane APIs, and the Google email must already be a dashboard user.
# GONVEX_DASHBOARD_AUTH_PROJECT_ID=dashboard-auth

# If the runtime is behind a reverse proxy, list only the proxy addresses or
# CIDRs that are allowed to supply X-Forwarded-For for auth rate limiting.
# GONVEX_TRUSTED_PROXY_CIDRS=10.0.0.0/8,192.0.2.10

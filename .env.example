POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gonvex_dev
POSTGRES_SSLMODE=disable
POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/gonvex_dev?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/gonvex_dev?sslmode=disable
# Optional runtime-side project database routing. Each project can use the same
# Postgres server with a different database name.
# GONVEX_PROJECT_DATABASE_URLS={"app":"postgres://postgres:postgres@127.0.0.1:5432/gonvex_dev?sslmode=disable","runtime":"postgres://postgres:postgres@127.0.0.1:5432/gonvex_runtime_dev?sslmode=disable"}

VALKEY_URL=redis://127.0.0.1:6380/0
GONVEX_ROWS_CACHE_TTL=15s

# Optional: only required when using file APIs. These values match the
# example MinIO service started by `make storage`. Any S3-compatible
# storage provider can be used instead.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=gonvex-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Browser-facing runtime origin. Required for Convex-compatible POST uploads:
# the runtime proxies storage traffic here instead of exposing MinIO/S3 URLs.
GONVEX_PUBLIC_URL=http://localhost:8080

# Optional native Google login. Configure one web OAuth client for the Gonvex
# runtime, with this authorized redirect URI:
#   http://localhost:8080/auth/google/callback
# Hosted runtimes must use their externally reachable HTTPS origin instead.
GONVEX_AUTH_URL=http://localhost:8080
# GONVEX_GOOGLE_CLIENT_ID=1234567890-example.apps.googleusercontent.com
# GONVEX_GOOGLE_CLIENT_SECRET=replace-me
